# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=transit_tracker
DATABASE_URL=postgresql://postgres:changeme@db:5432/transit_tracker

# Redis
REDIS_URL=redis://localhost:6379

# Agency configuration
AGENCY_CONFIG_PATH=./config/agencies.json

# API keys (referenced by agencies.json apiKeyEnvVar)
MBTA_API_KEY=your_mbta_api_key_here

# Run GTFS static ingestion on worker startup (set to true only when you need to re-ingest)
# Leave unset or false in normal operation — the nightly cron handles refreshes
GTFS_INGEST_ON_STARTUP=false

# GTFS ingestion schedule (cron expression, default: 4am daily)
GTFS_STATIC_CRON=0 4 * * *

# Realtime polling interval in milliseconds (default: 15000 = 15s)
GTFS_REALTIME_POLL_INTERVAL_MS=15000

# Node environment
NODE_ENV=development

# Worker liveness file path
WORKER_FILE_LIVENESS_PATH=/tmp/worker-alive
