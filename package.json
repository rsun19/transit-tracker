{
  "name": "transit-tracker",
  "private": true,
  "workspaces": [
    "packages/shared",
    "services/agencies",
    "services/alerts",
    "services/vehicles",
    "services/routes",
    "services/stops",
    "services/ingestion"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "docker-compose -f docker-compose.dev.yml up --build",
    "dev:down": "docker-compose -f docker-compose.dev.yml down",
    "start": "docker compose up --build",
    "stop": "docker compose down",
    "logs": "docker compose logs -f",
    "logs:backend": "docker compose logs -f backend",
    "logs:worker": "docker compose logs -f worker",
    "logs:frontend": "docker compose logs -f frontend",
    "lint": "node scripts/ci/lint-workspace.mjs",
    "lint:fix": "node scripts/ci/lint-workspace.mjs --fix",
    "format": "prettier --write \"**/*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}\"",
    "test:unit": "npm run test:cov --prefix services/agencies && npm run test:cov --prefix services/alerts && npm run test:cov --prefix services/vehicles && npm run test:cov --prefix services/routes && npm run test:cov --prefix services/stops && npm run test:cov --prefix services/ingestion && npm run test:cov --prefix frontend && node scripts/ci/check-unit-coverage.mjs",
    "test:integration": "node scripts/ci/run-gate.mjs integration",
    "test:contract": "node scripts/ci/run-gate.mjs contract",
    "test:a11y": "node scripts/ci/run-accessibility-gate.mjs",
    "test:performance": "node scripts/ci/run-performance-gate.mjs",
    "test:e2e": "node scripts/e2e/run-all-cypress-headless.mjs",
    "test:e2e:group": "node scripts/e2e/run-cypress-group.mjs",
    "test:e2e:open": "node scripts/e2e/open-cypress-interactive.mjs",
    "test:e2e:local": "bash scripts/e2e/run-local-e2e.sh",
    "typecheck": "node scripts/ci/typecheck-workspace.mjs",
    "test:all": "npm run lint && npm run format:check && npm run test:unit && npm run test:integration && npm run test:contract && npm run test:a11y && npm run test:performance && npm run test:e2e:local",
    "test": "npm run test:all",
    "ci:gate": "node scripts/ci/run-gate.mjs",
    "ci:assert-checks": "node scripts/ci/assert-required-checks.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "cypress": "^14.4.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "typescript": "^6.0.2"
  }
}
